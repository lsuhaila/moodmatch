###### Function Definitions ######

## FUNCTION: print_welcome ##
# - Prints the welcome message at the start of the program.
# - This is the "Print Welcome message" box in our flowchart.

def print_welcome():
    print("=" * 50 + "\n             MOOD MATCH READS\n     Where your mood meets your next read.\n" + "=" * 50)
    print("\nHi there! Welcome to Mood Match Reads.\nTell us a bit about what you are in the mood for\nand we will find your next favorite book.\n")



## FUNCTION: print_list ##
# - Prints a list of words from genre or moods lists and prints each one to the screen with a number next to it. Allows user to type in the number or the word. 

def print_list(options):
    for i in range(len(options)):
        # Add 1 so the list starts at "1." since Python counts from 0. str used to turn the integer into string to be added to the options.
        print("  " + str(i + 1) + ". " + options[i])



## FUNCTION: ask_for_choice ##
# - Asks the user to pick something from a list. This could be genre or mood. Keeps asking until they give a valid answer or skip. 

def ask_for_choice(question, options):
    # Show the question and the list of options. Options are what is in the genre and mood lists. 
    print(question)
    print_list(options)

    # Loop until we get a valid answer
    while True:
        answer = input("Choose a number, a word, or press Enter to skip: ")
        # .strip() removes extra spaces and .lower() makes it case-insensitive
        answer = answer.strip().lower()

        # when Enter pressed --> Skip
        if answer == "":
            return ""

        # If number chosen, check that the chosen number is in range
        if answer.isdigit():
            #change answer from string to integer to check if it is in range of the options
            number = int(answer)
            if number >= 1 and number <= len(options):
                # number 1 means index 0, so we subtract 1
                return options[number - 1]
            else:
                print("Invalid input. Please pick a number between 1 and " + str(len(options)) + ".")

        # If word chosen, check that the chosen word matches an option
        elif answer in options:
            return answer

        # Anything else is invalid
        else:
            print("Invalid input. Please type a number from the list, "
                  "the name of an option, or press Enter to skip.")



## FUNCTION: ask_for_author ##
# - Asks the user for their favorite author. Returns the name they typed, or "" if they skipped.

def ask_for_author():
    answer = input("\nFavorite author? (type a name or press Enter to skip): ")
    return answer.strip()


## FUNCTION: ask_yes_no ##
# Asks a yes/no question and keeps asking until we get a valid answer. Returns True for yes, False for no.
# This is for when we ask 'would you like 5 more recommendations' or 'try a new search' 

def ask_yes_no(question):
    while True:
        answer = input(question).strip().lower()
        if answer == "yes" or answer == "y":
            return True
        elif answer == "no" or answer == "n":
            return False
        else:
            print("Invalid input. Please type 'yes' or 'no'.")



## FUNCTION: rank_books ##
# - This function creates the list of relevant books and ranks them based on user preference. This is the "Filter books based on preferences" + "Rank matches by relevance" boxes from the flowchart.
# - Goes through every book and gives it a score. Higher score means a better match for the user.

def rank_books(mood, genre, author):
    # New list to hold matched books with score in the format:[score, title, author, genre, rating] 
    scored_books = [] 

    for book in BOOKS:
        # Get the parts of this book
        title = book[0]
        book_author = book[1]
        book_genre = book[2]
        book_mood = book[3]
        rating = book[4]

        # Start the score at 0
        score = 0

        # Add 3 points if the mood matches
        if mood != "" and book_mood == mood:
            score = score + 3

        # Add 2 points if the genre matches
        if genre != "" and book_genre == genre:
            score = score + 2

        # Add 3 points if the author matches
        if author != "":
             # use .lower() to make it case insensitive
            if author.lower() in book_author.lower():
                score = score + 3

        # Only keep book that matches at least one preference 
        if score > 0:
            # if the score for 2 or more books are the same, then the rating of individual books are added to the score to break the tie. 
            score = score + rating

            # Save it as [score, title, author, genre, rating]
            scored_books.append([score, title, book_author, book_genre, rating])

    # Sort the list from smallest to biggest first.
    scored_books.sort()

    # [::-1] slice used to flip the sorted list to make the higher rated one come first. 
    scored_books = scored_books[::-1]

    return scored_books



## FUNCTION: show_books ##
# - Prints a page of 5 books to the screen.
# - start_index is which book to start at (0 = first page, 5 = second page, 10 = third page, etc.)

def show_books(scored_books, start_index):
    print("\n" + "-" * 50 + "\n  Your matches:\n" + "-" * 50)

    # Show 5 books starting at start_index
    end_index = start_index + 5
    # But if fewer than 5 books are left, stop at the end of the list
    if end_index > len(scored_books):
        end_index = len(scored_books)

    for i in range(start_index, end_index):
        book = scored_books[i]
        # book is [score, title, author, genre, rating]
        title = book[1]
        author = book[2]
        genre = book[3]
        rating = book[4]
        print("\n  " + str(i + 1) + ". " + title + "\n     by " + author + "\n     Genre: " + genre + "   Rating: " + str(rating) + " / 5")

    print()



## FUNCTION: main program ##
# - The main program. Puts everything together and follows the flowchart from start to end.

def main():
    print_welcome()

    # The big outer loop - keeps running until the user quits.
    # This lets the user start a new search with new preferences without restarting the program.
    while True:

        # ---- STEP 1: Ask for preferences ----
        # This is the "Prompt user to enter mood, genre, or favorite author" box in the flowchart.
        print("Step 1: Tell us your preferences\n(You can skip any of these by pressing Enter)\n")

        #asking the questions for user selection on mood, genre, and author. 
        mood = ask_for_choice("\nWhat mood are you in?", MOODS)
        genre = ask_for_choice("\nWhat genre do you want?", GENRES)
        author = ask_for_author()

        # "Input Valid?" diamond - the user must answer at least one question
        if mood == "" and genre == "" and author == "":
            print()
            print("Invalid input. Please answer at least one question")
            print("so we can find a book for you.")
            print()
            continue  # go back to the top and ask again

        # ---- STEP 2: Rank the books ----
        # This is the "Filter books based on preferences" and
        # "Rank matches by relevance" boxes.
        scored_books = rank_books(mood, genre, author)

        # If no books matched, ask if they want to try again
        if len(scored_books) == 0:
            print()
            print("No books matched your preferences. Try different ones!")
            print()
            if ask_yes_no("Try a new search? (yes/no): "):
                continue  # ask again
            else:
                # Print goodbye and end the program
                print()
                print("=" * 50)
                print("  Thanks for using Mood Match Reads!")
                print("  Happy reading!")
                print("=" * 50)
                return

        # ---- STEP 3: Show 5 books at a time ----
        # This is the "Return top 5 recommendations" box and the
        # loop for "Display next 5 recommendations".
        start_index = 0
        showing_books = True
        while showing_books:
            show_books(scored_books, start_index)
            start_index = start_index + 5

            # Check if there are more books to show
            if start_index >= len(scored_books):
                print("That's all the books we found!")
                showing_books = False
            else:
                # The "More recommendations?" diamond
                if ask_yes_no("Want to see 5 more? (yes/no): "):
                    pass  # loop back and show the next 5
                else:
                    showing_books = False

        # ---- STEP 4: New search or quit? ----
        # This is the second decision diamond from the new flowchart:
        # "more recs or new selection of preferences?"
        print()
        print("What would you like to do next?")
        print("  1. Start a new search with different preferences")
        print("  2. Quit Mood Match Reads")

        # Loop until they pick 1 or 2
        while True:
            choice = input("Pick 1 or 2: ").strip()
            if choice == "1":
                print()
                break  # break out of this small loop, big loop continues
            elif choice == "2":
                # Print goodbye and end the program
                print()
                print("=" * 50)
                print("  Thanks for using Mood Match Reads!")
                print("  Happy reading!")
                print("=" * 50)
                return
            else:
                print("Invalid input. Please type 1 or 2.")


# ---------------------------------------------------------------
# This runs the main() function when we run the file.
# Without this, the program would do nothing!
# ---------------------------------------------------------------
main()